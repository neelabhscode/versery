# Optional: canonical, Open Graph, and JSON-LD base URL (no trailing slash).
# Defaults to https://www.versery.today if unset.
# VITE_SITE_URL=https://your-production-domain.com

# Newsletter signups POST to /api/newsletter-signup by default (appends to data/newsletter-signups.txt
# in local dev). On Vercel, link a Blob store so BLOB_READ_WRITE_TOKEN is available, or set this to
# your provider’s endpoint when you wire a real newsletter.
# VITE_NEWSLETTER_ACTION_URL=
